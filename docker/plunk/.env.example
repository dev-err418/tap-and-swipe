# Plunk env vars. Paste into Coolify's "Environment Variables" panel for the
# Plunk service. Values shown are placeholders — replace before deploying.

# Postgres password (also embedded in DATABASE_URL inside docker-compose).
# Generate: openssl rand -hex 24
DB_PASSWORD=changeme-postgres-password

# JWT signing secret for Plunk auth. 32+ random bytes.
# Generate: openssl rand -hex 32
JWT_SECRET=changeme-jwt-secret

# AWS SES — region confirmed via your existing MX record
# (feedback-smtp.eu-west-1.amazonses.com).
AWS_SES_REGION=eu-west-1
AWS_SES_ACCESS_KEY_ID=AKIA...
AWS_SES_SECRET_ACCESS_KEY=...

# SES Configuration Sets created in step A2. Names are arbitrary; these match
# the docs' suggested names and the docker-compose defaults.
SES_CONFIGURATION_SET=plunk-tracking
SES_CONFIGURATION_SET_NO_TRACKING=plunk-no-tracking

# Bundled Minio (object storage for uploads inside Plunk's UI). The user is
# only used internally between containers; no external access.
MINIO_ROOT_USER=plunk
MINIO_ROOT_PASSWORD=changeme-minio-password
S3_BUCKET=uploads

# Public URL Plunk uses to render uploaded images in emails/dashboard.
# Pointed at the api subdomain since that's where Plunk serves /uploads.
S3_PUBLIC_URL=https://plunk-api.tap-and-swipe.com/uploads
