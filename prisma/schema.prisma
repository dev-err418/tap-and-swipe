generator client {
  provider   = "prisma-client"
  output     = "../lib/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Core tables ─────────────────────────────────────────────────────────

model User {
  id                 String             @id @default(cuid())
  email              String?            @unique
  name               String?
  image              String?
  // Discord (primary auth)
  discordId          String?            @unique
  discordUsername     String?
  discordAvatar      String?
  discordAccessToken String?
  // GitHub (optional, for boilerplate repo access)
  githubId           String?            @unique
  githubUsername      String?
  githubConnectedAt  DateTime?
  // Payment
  stripeCustomerId   String?            @unique
  paddleCustomerId   String?            @unique
  paymentProvider    String?            // "stripe" | "paddle" | "whop"
  subscriptionId     String?            @unique
  subscriptionStatus String?
  tier               String?            // "full" | "starter"
  roleGranted        Boolean            @default(false)
  discordTrialExpiry DateTime?
  // Attribution
  visitorId          String?            // visitor_id cookie captured at checkout, for analytics attribution
  // Relations
  lessonProgress     LessonProgress[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([stripeCustomerId])
  @@index([paddleCustomerId])
  @@index([subscriptionId])
  @@index([visitorId])
}

model Lesson {
  id              String           @id @default(cuid())
  category        String
  title           String
  description     String?
  type            String           @default("video")
  videoUrl        String?          // R2 URL for self-hosted video
  youtubeUrl      String?          // Legacy YouTube URL (migration period)
  markdownContent String?
  sectionType     String?          // null | "github-connect"
  order           Int
  progress        LessonProgress[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([category, order])
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  lessonId    String
  lesson      Lesson    @relation(fields: [lessonId], references: [id])
  completedAt DateTime  @default(now())
  uncheckedAt DateTime?

  @@unique([userId, lessonId])
  @@index([userId])
}

// ── Invites ───────────────────────────────────────────────────────────

model InviteLink {
  id        String    @id @default(cuid())
  token     String    @unique
  tier      String    @default("boilerplate")
  usedAt    DateTime?
  discordId String?
  createdAt DateTime  @default(now())
}

// ── Analytics & Events ──────────────────────────────────────────────────

model PageEvent {
  id               String   @id @default(cuid())
  product          String   // "aso" | "community" | "quiz" | "coaching"
  type             String   // "page_view" | "cta_clicked" | "stripe_shown" | "paid" | "quiz_start" | "quiz_complete"
  visitorId        String   // cookie-based, persists across sessions (1yr)
  sessionId        String   // per browser-session, for within-session dedup
  country          String?  // x-vercel-ip-country
  referrer         String?  // document.referrer or UTM source
  ref              String?  // URL param ?ref=vid1 etc. for traffic source tracking
  stripeCustomerId String?  // set at stripe_shown / paid time
  revenue          Int?     // amount in cents, set on "paid" events
  currency         String?  // e.g. "eur", set on "paid" events
  createdAt        DateTime @default(now())

  @@unique([sessionId, type, product])
  @@index([product, type, createdAt])
  @@index([visitorId])
  @@index([product, country, createdAt])
  @@index([ref, createdAt])
}

// ── Quiz Funnel ───────────────────────────────────────────────────────

model QuizLead {
  id        String   @id @default(cuid())
  firstName String
  email     String
  hasApp    String   // "revenue" | "no-revenue" | "idea" | "scratch"
  challenge String?  // open-text: biggest challenge
  budget    String?  // "under-500" | "500-2000" | "2000-plus"
  route     String   // "coaching" | "community"
  ref       String?  // URL param ?ref=vid1
  country   String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([route, createdAt])
}

// ── Discord ─────────────────────────────────────────────────────────────

model TrialDiscordMessage {
  id                    String   @id @default(cuid())
  appName               String
  appUserId             String
  originalTransactionId String
  discordMessageId      String
  createdAt             DateTime @default(now())

  @@unique([appName, originalTransactionId])
  @@index([appUserId])
}
